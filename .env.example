# IBM Cloud Ops Agent environment configuration
# Copy this file to .env and replace placeholder values with real credentials:
#   cp .env.example .env
#
# Required values are used by deploy.sh and verify_credentials.py.
# Optional values enable additional integrations.

# ──────────────────────────────────────────────────────────────
# Required: IBM Cloud core + watsonx Orchestrate
# ──────────────────────────────────────────────────────────────
IBMCLOUD_API_KEY=your_ibm_cloud_api_key
IBMCLOUD_ACCOUNT_ID=your_ibm_cloud_account_id
IBMCLOUD_REGION=us-south

# Orchestrate instance URL (SaaS) or CPD route URL
WO_INSTANCE=https://api.us-south.watson-orchestrate.watson.cloud.ibm.com/instances/your_instance_id
WO_API_KEY=your_watsonx_orchestrate_api_key
WO_ENV_NAME=local

# Optional CPD-only credentials (if your deployment requires them)
WO_USERNAME=
WO_PASSWORD=

# Alternative model access credentials (if using watsonx directly instead of WO creds)
WATSONX_SPACE_ID=
WATSONX_APIKEY=

# ──────────────────────────────────────────────────────────────
# Optional: IBM Cloud Code Engine
# ──────────────────────────────────────────────────────────────
CODE_ENGINE_PROJECT_ID=
CODE_ENGINE_REGION=us-south

# ──────────────────────────────────────────────────────────────
# Optional: IBM Cloud Logs
# Use the same instance GUID for both values.
# ──────────────────────────────────────────────────────────────
CLOUD_LOGS_INSTANCE_ID=
CLOUD_LOGS_INSTANCE_GUID=
CLOUD_LOGS_REGION=us-south

# ──────────────────────────────────────────────────────────────
# Optional: IBM Cloud Monitoring (Sysdig)
# ──────────────────────────────────────────────────────────────
MONITORING_API_TOKEN=
MONITORING_ENDPOINT=https://us-south.monitoring.cloud.ibm.com

# ──────────────────────────────────────────────────────────────
# Optional: IBM Cloud Databases
# ──────────────────────────────────────────────────────────────
ICD_REGION=us-south
ICD_RESOURCE_GROUP=default
